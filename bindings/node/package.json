{
  "name": "@libraz/libsonare-native",
  "version": "1.2.2",
  "description": "Audio analysis library - Node.js binding (native N-API)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "scripts/",
    "build/Release/*.node"
  ],
  "scripts": {
    "build:native": "node scripts/build-native.mjs",
    "build": "yarn build:native && tsc",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.12.0",
  "volta": {
    "node": "22.21.1",
    "yarn": "4.12.0"
  },
  "dependencies": {
    "cmake-js": "^8.0.0",
    "node-addon-api": "^8.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
