{
  "name": "@libraz/libsonare-native",
  "version": "1.0.0",
  "description": "Audio analysis library - Node.js binding (native N-API)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/", "build/Release/*.node"],
  "scripts": {
    "build:native": "cmake-js compile",
    "build": "npm run build:native && tsc",
    "check": "biome check src/ tests/",
    "check:fix": "biome check --write src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "Apache-2.0",
  "engines": { "node": ">=22" },
  "packageManager": "yarn@4.12.0",
  "volta": { "node": "22.21.1", "yarn": "4.12.0" },
  "dependencies": {
    "cmake-js": "^7.3.0",
    "node-addon-api": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "2",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
